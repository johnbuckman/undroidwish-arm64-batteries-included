+/*
+ *----------------------------------------------------------------------
+ * usbdevices via IOKit.
+ *----------------------------------------------------------------------
+ */
+
+static void
+BorgIOKitInt(io_service_t dev, CFStringRef key, Tcl_Obj *dict,
+	     const char *outkey)
+{
+    CFTypeRef ref = IORegistryEntryCreateCFProperty(dev, key,
+						    kCFAllocatorDefault, 0);
+    if (ref != NULL) {
+	if (CFGetTypeID(ref) == CFNumberGetTypeID()) {
+	    long long v = 0;
+	    CFNumberGetValue((CFNumberRef) ref, kCFNumberLongLongType, &v);
+	    Tcl_DictObjPut(NULL, dict, Tcl_NewStringObj(outkey, -1),
+			   Tcl_NewWideIntObj((Tcl_WideInt) v));
+	}
+	CFRelease(ref);
+    }
+}
+
+static void
+BorgIOKitStr(io_service_t dev, CFStringRef key, Tcl_Obj *dict,
+	     const char *outkey)
+{
+    CFTypeRef ref = IORegistryEntryCreateCFProperty(dev, key,
+						    kCFAllocatorDefault, 0);
+    if (ref != NULL) {
+	if (CFGetTypeID(ref) == CFStringGetTypeID()) {
+	    char buf[512];
+	    if (CFStringGetCString((CFStringRef) ref, buf, sizeof(buf),
+				   kCFStringEncodingUTF8)) {
+		Tcl_DictObjPut(NULL, dict, Tcl_NewStringObj(outkey, -1),
+			       Tcl_NewStringObj(buf, -1));
+	    }
+	}
+	CFRelease(ref);
+    }
+}
+
+static int
+BorgUsbDevices(Tcl_Interp *interp)
+{
+    Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+    CFMutableDictionaryRef match = IOServiceMatching("IOUSBDevice");
+    io_iterator_t it = 0;
+    /* 0 == kIOMainPortDefault (macOS 12+) == kIOMasterPortDefault (older). */
+    const mach_port_t mainPort = 0;
+
+    if (match == NULL) {
+	/* Older/newer class name fallback. */
+	match = IOServiceMatching("IOUSBHostDevice");
+    }
+    if (match != NULL &&
+	IOServiceGetMatchingServices(mainPort, match, &it)
+	== KERN_SUCCESS) {
+	io_service_t dev;
+	while ((dev = IOIteratorNext(it)) != 0) {
+	    Tcl_Obj *d = Tcl_NewDictObj();
+	    BorgIOKitInt(dev, CFSTR("idVendor"), d, "vendor");
+	    BorgIOKitInt(dev, CFSTR("idProduct"), d, "product");
+	    BorgIOKitStr(dev, CFSTR("USB Vendor Name"), d, "manufacturer");
+	    BorgIOKitStr(dev, CFSTR("USB Product Name"), d, "name");
+	    BorgIOKitStr(dev, CFSTR("USB Serial Number"), d, "serial");
+	    Tcl_ListObjAppendElement(NULL, list, d);
+	    IOObjectRelease(dev);
+	}
+	IOObjectRelease(it);
+    }
+    Tcl_SetObjResult(interp, list);
+    return TCL_OK;
+}
