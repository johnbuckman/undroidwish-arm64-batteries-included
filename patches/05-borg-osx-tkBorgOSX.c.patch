+static int
+BorgEmptyCursor(Tcl_Interp *interp)
+{
+    static int seq = 0;
+    char name[64];
+
+    snprintf(name, sizeof(name), "::borg::cursor%d", ++seq);
+    Tcl_CreateObjCommand(interp, name, BorgCursorObjCmd, NULL, NULL);
+    Tcl_SetObjResult(interp, Tcl_NewStringObj(name, -1));
+    return TCL_OK;
+}
