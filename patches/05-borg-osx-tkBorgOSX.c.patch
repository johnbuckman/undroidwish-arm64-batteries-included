+/*
+ * Subcommand handlers for sharedpreferences.  Returns a Tcl status.
+ *   borg sharedpreferences FILE OP ?KEY VALUE?
+ */
+static int
+BorgSharedPrefs(Tcl_Interp *interp, int objc, Tcl_Obj *const objv[])
+{
+    static const char *const shpCmds[] = {
+	"getboolean", "getfloat", "getint", "getlong", "getstring",
+	"setboolean", "setfloat", "setint", "setlong", "setstring",
+	"remove", "clear", "all", "alltypes", "keys", NULL
+    };
+    enum shpCmd {
+	SHP_getbool, SHP_getfloat, SHP_getint, SHP_getlong, SHP_getstring,
+	SHP_setbool, SHP_setfloat, SHP_setint, SHP_setlong, SHP_setstring,
+	SHP_remove, SHP_clear, SHP_all, SHP_alltypes, SHP_keys
+    };
+    int cmd;
+    const char *file;
+    Tcl_Obj *dict, *key = NULL, *stored = NULL;
+
+    if ((objc < 4) || (objc > 6)) {
+	Tcl_WrongNumArgs(interp, 2, objv, "file op ?key value?");
+	return TCL_ERROR;
+    }
+    if (Tcl_GetIndexFromObj(interp, objv[3], shpCmds, "option", 0,
+			    &cmd) != TCL_OK) {
+	return TCL_ERROR;
+    }
+    file = Tcl_GetString(objv[2]);
+    if (objc > 4) {
+	key = objv[4];
+    }
+    dict = BorgPrefsLoad(file);
+    Tcl_IncrRefCount(dict);
+
+    if (key != NULL) {
+	Tcl_DictObjGet(NULL, dict, key, &stored);
+    }
+
+    switch ((enum shpCmd) cmd) {
+    case SHP_getbool: case SHP_getfloat: case SHP_getint:
+    case SHP_getlong: case SHP_getstring: {
+	/* objv[5] is the default if missing. */
+	Tcl_Obj *val = NULL;
+	if (objc != 6) {
+	    Tcl_DecrRefCount(dict);
+	    Tcl_WrongNumArgs(interp, 2, objv, "file getX key default");
+	    return TCL_ERROR;
+	}
+	if (stored != NULL) {
+	    /* stored = {type value}; take value (last element). */
+	    int n;
+	    Tcl_Obj **el;
+	    if (Tcl_ListObjGetElements(NULL, stored, &n, &el) == TCL_OK &&
+		n == 2) {
+		val = el[1];
+	    } else {
+		val = stored;
+	    }
+	}
+	if (val == NULL) {
+	    val = objv[5];
+	}
+	Tcl_SetObjResult(interp, val);
+	break;
+    }
+    case SHP_setbool: case SHP_setfloat: case SHP_setint:
+    case SHP_setlong: case SHP_setstring: {
+	const char *type;
+	Tcl_Obj *pair;
+	if (objc != 6) {
+	    Tcl_DecrRefCount(dict);
+	    Tcl_WrongNumArgs(interp, 2, objv, "file setX key value");
+	    return TCL_ERROR;
+	}
+	switch ((enum shpCmd) cmd) {
+	case SHP_setbool:   type = "boolean"; break;
+	case SHP_setfloat:  type = "float";   break;
+	case SHP_setint:    type = "int";     break;
+	case SHP_setlong:   type = "long";    break;
+	default:            type = "string";  break;
+	}
+	pair = Tcl_NewListObj(0, NULL);
+	Tcl_ListObjAppendElement(NULL, pair, Tcl_NewStringObj(type, -1));
+	Tcl_ListObjAppendElement(NULL, pair, objv[5]);
+	Tcl_DictObjPut(NULL, dict, key, pair);
+	BorgPrefsSave(file, dict);
+	Tcl_SetObjResult(interp, objv[5]);
+	break;
+    }
+    case SHP_remove:
+	if (key != NULL) {
+	    Tcl_DictObjRemove(NULL, dict, key);
+	    BorgPrefsSave(file, dict);
+	}
+	break;
+    case SHP_clear: {
+	Tcl_Obj *empty = Tcl_NewDictObj();
+	BorgPrefsSave(file, empty);
+	Tcl_DecrRefCount(empty);
+	break;
+    }
+    case SHP_keys: {
+	Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+	Tcl_DictSearch s;
+	Tcl_Obj *k, *v;
+	int done;
+	if (Tcl_DictObjFirst(NULL, dict, &s, &k, &v, &done) == TCL_OK) {
+	    for (; !done; Tcl_DictObjNext(&s, &k, &v, &done)) {
+		Tcl_ListObjAppendElement(NULL, list, k);
+	    }
+	    Tcl_DictObjDone(&s);
+	}
+	Tcl_SetObjResult(interp, list);
+	break;
+    }
+    case SHP_all: case SHP_alltypes: {
+	Tcl_Obj *out = Tcl_NewListObj(0, NULL);
+	Tcl_DictSearch s;
+	Tcl_Obj *k, *v;
+	int done;
+	if (Tcl_DictObjFirst(NULL, dict, &s, &k, &v, &done) == TCL_OK) {
+	    for (; !done; Tcl_DictObjNext(&s, &k, &v, &done)) {
+		int n;
+		Tcl_Obj **el;
+		Tcl_ListObjAppendElement(NULL, out, k);
+		if (cmd == SHP_alltypes) {
+		    /* {type value} */
+		    Tcl_ListObjAppendElement(NULL, out, v);
+		} else if (Tcl_ListObjGetElements(NULL, v, &n, &el) == TCL_OK
+			   && n == 2) {
+		    Tcl_ListObjAppendElement(NULL, out, el[1]);
+		} else {
+		    Tcl_ListObjAppendElement(NULL, out, v);
+		}
+	    }
+	    Tcl_DictObjDone(&s);
+	}
+	Tcl_SetObjResult(interp, out);
+	break;
+    }
+    }
+    Tcl_DecrRefCount(dict);
+    return TCL_OK;
+}
