+/*
+ *----------------------------------------------------------------------
+ * onintent callback storage.
+ *----------------------------------------------------------------------
+ */
+
+static Tcl_Obj *borgOnIntent = NULL;
+
+/*
+ *----------------------------------------------------------------------
+ * The main "borg" dispatcher.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgObjCmd(ClientData clientData, Tcl_Interp *interp, int objc,
+	   Tcl_Obj *const objv[])
+{
+    static const char *const borgCmds[] = {
+	"activity", "alarm", "beep", "bluetooth",
+	"brightness", "broadcast", "camera", "cancel",
+	"checkpermission",
+	"content", "displaymetrics", "endspeak", "isspeaking",
+	"keyboardinfo", "locale", "location", "log",
+	"ndefformat", "ndefread", "ndefwrite", "networkinfo",
+	"notification", "onintent", "osbuildinfo",
+	"osenvironment", "packageinfo", "phoneinfo", "providerinfo",
+	"queryactivities", "querybroadcastreceivers",
+	"queryconsts", "queryfeatures", "queryfields",
+	"queryservices",
+	"screenorientation", "sendsms", "sensor",
+	"sharedpreferences", "shortcut",
+	"speak", "speechrecognition", "spinner", "stopspeak",
+	"systemproperties", "systemui", "tetherinfo", "toast",
+	"trace", "usbdevices", "usbpermission", "vibrate",
+	"withdraw", NULL
+    };
+    enum borgCmd {
+	BORG_activity, BORG_alarm, BORG_beep, BORG_bluetooth,
+	BORG_brightness, BORG_broadcast, BORG_camera, BORG_cancel,
+	BORG_checkpermission,
+	BORG_content, BORG_displaymetrics, BORG_endspeak, BORG_isspeaking,
+	BORG_keyboardinfo, BORG_locale, BORG_location, BORG_log,
+	BORG_ndefformat, BORG_ndefread, BORG_ndefwrite, BORG_networkinfo,
+	BORG_notification, BORG_onintent, BORG_osbuildinfo,
+	BORG_osenvironment, BORG_packageinfo, BORG_phoneinfo, BORG_providerinfo,
+	BORG_queryactivities, BORG_querybroadcastreceivers,
+	BORG_queryconsts, BORG_queryfeatures, BORG_queryfields,
+	BORG_queryservices,
+	BORG_screenorientation, BORG_sendsms, BORG_sensor,
+	BORG_sharedpreferences, BORG_shortcut,
+	BORG_speak, BORG_speechrecognition, BORG_spinner, BORG_stopspeak,
+	BORG_systemproperties, BORG_systemui, BORG_tetherinfo, BORG_toast,
+	BORG_trace, BORG_usbdevices, BORG_usbpermission, BORG_vibrate,
+	BORG_withdraw
+    };
+    int command;
+
+    if (objc < 2) {
+	Tcl_WrongNumArgs(interp, 1, objv, "option ?arg ...?");
+	return TCL_ERROR;
+    }
+    if (Tcl_GetIndexFromObj(interp, objv[1], borgCmds, "option", 0,
+			    &command) != TCL_OK) {
+	return TCL_ERROR;
+    }
+
+    switch ((enum borgCmd) command) {
+
+    /* ---- Native implementations ------------------------------------ */
+
+    case BORG_log: {				/* borg log prio tag message */
+	if (objc != 5) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "prio tag message");
+	    return TCL_ERROR;
+	}
+	fprintf(stderr, "%s/%s: %s\n", Tcl_GetString(objv[2]),
+		Tcl_GetString(objv[3]), Tcl_GetString(objv[4]));
+	fflush(stderr);
+	return TCL_OK;
+    }
+
+    case BORG_trace: {				/* borg trace message script */
+	if (objc != 4) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "message script");
+	    return TCL_ERROR;
+	}
+	return Tcl_EvalObjEx(interp, objv[3], 0);
+    }
+
+    case BORG_beep: {				/* borg beep ?uri? */
+	if (objc > 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "?uri?");
+	    return TCL_ERROR;
+	}
+	if (objc == 3) {
+	    const char *argv[3];
+	    argv[0] = "afplay";
+	    argv[1] = Tcl_GetString(objv[2]);
+	    argv[2] = NULL;
+	    (void) BorgSpawn(argv);
+	} else {
+	    const char *argv[4];
+	    argv[0] = "osascript";
+	    argv[1] = "-e";
+	    argv[2] = "beep";
+	    argv[3] = NULL;
+	    (void) BorgSpawn(argv);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_vibrate: {			/* borg vibrate duration */
+	int dur;
+	if (objc != 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "duration");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIntFromObj(interp, objv[2], &dur) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	/* No vibration hardware on the Mac -- accepted no-op. */
+	return TCL_OK;
+    }
+
+    case BORG_toast: {				/* borg toast text ?longdur? */
+	int dur = 0;
+	if ((objc < 3) || (objc > 4)) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "text ?longdur?");
+	    return TCL_ERROR;
+	}
+	if ((objc > 3) &&
+	    (Tcl_GetBooleanFromObj(interp, objv[3], &dur) != TCL_OK)) {
+	    return TCL_ERROR;
+	}
+	BorgEnsureTkHelpers(interp);
+	{
+	    Tcl_Obj *cmd = Tcl_NewListObj(0, NULL);
+	    Tcl_ListObjAppendElement(NULL, cmd,
+		Tcl_NewStringObj("::borg::ui::toast", -1));
+	    Tcl_ListObjAppendElement(NULL, cmd, objv[2]);
+	    Tcl_ListObjAppendElement(NULL, cmd, Tcl_NewIntObj(dur));
+	    Tcl_IncrRefCount(cmd);
+	    (void) Tcl_EvalObjEx(interp, cmd, TCL_EVAL_DIRECT);
+	    Tcl_DecrRefCount(cmd);
+	    Tcl_ResetResult(interp);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_spinner: {			/* borg spinner bool */
+	int on;
+	if (objc != 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "bool");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetBooleanFromObj(interp, objv[2], &on) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	BorgEnsureTkHelpers(interp);
+	{
+	    char buf[64];
+	    snprintf(buf, sizeof(buf), "::borg::ui::spinner %d", on);
+	    BorgEvalIgnore(interp, buf);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_speak: {			/* borg speak text ?lang pitch rate? */
+	if ((objc < 3) || (objc > 6)) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "text ?lang pitch rate?");
+	    return TCL_ERROR;
+	}
+	return BorgSpeak(interp, Tcl_GetString(objv[2]),
+			 (objc > 5) ? Tcl_GetString(objv[5]) : NULL);
+    }
+
+    case BORG_stopspeak:
+    case BORG_endspeak: {
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	if (borgSayPid > 0 && kill(borgSayPid, 0) == 0) {
+	    kill(borgSayPid, SIGTERM);
+	}
+	borgSayPid = 0;
+	return TCL_OK;
+    }
+
+    case BORG_isspeaking: {
+	int speaking;
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	speaking = (borgSayPid > 0 && kill(borgSayPid, 0) == 0) ? 1 : 0;
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(speaking));
+	return TCL_OK;
+    }
+
+    case BORG_activity: {		/* borg activity action uri type ... */
+	/* Map the common VIEW intent to `open <uri>`. */
+	if ((objc < 5) || (objc > 9)) {
+	    Tcl_WrongNumArgs(interp, 2, objv,
+			     "action uri type ?cats comp args callback?");
+	    return TCL_ERROR;
+	}
+	{
+	    const char *action = Tcl_GetString(objv[2]);
+	    const char *uri = Tcl_GetString(objv[3]);
+	    if (strstr(action, "VIEW") != NULL && uri[0] != '\0') {
+		const char *argv[3];
+		argv[0] = "open";
+		argv[1] = uri;
+		argv[2] = NULL;
+		(void) BorgSpawn(argv);
+	    }
+	    /* other intents: accepted no-op */
+	}
+	return TCL_OK;
+    }
+
+    case BORG_brightness: {			/* borg brightness ?pct? */
+	DSGetBrightnessFn getfn;
+	DSSetBrightnessFn setfn;
+	if (objc > 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "?percentage?");
+	    return TCL_ERROR;
+	}
+	if (!BorgBrightnessFns(&getfn, &setfn)) {
+	    /* No DisplayServices: report 100, accept sets as no-op. */
+	    if (objc == 2) {
+		Tcl_SetObjResult(interp, Tcl_NewIntObj(100));
+	    }
+	    return TCL_OK;
+	}
+	if (objc == 2) {
+	    float b = 1.0f;
+	    getfn(CGMainDisplayID(), &b);
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj((int)(b * 100.0f + 0.5f)));
+	} else {
+	    int pct;
+	    if (Tcl_GetIntFromObj(interp, objv[2], &pct) != TCL_OK) {
+		return TCL_ERROR;
+	    }
+	    if (pct < 0) pct = 0;
+	    if (pct > 100) pct = 100;
+	    setfn(CGMainDisplayID(), (float) pct / 100.0f);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_displaymetrics:
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	return BorgDisplayMetrics(interp);
+
+    case BORG_osbuildinfo:
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	return BorgOSBuildInfo(interp);
+
+    case BORG_networkinfo:
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	return BorgNetworkInfo(interp);
+
+    case BORG_keyboardinfo:
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	/* Desktop: a hardware keyboard is always present and shown. */
+	Tcl_SetObjResult(interp,
+	    Tcl_NewStringObj("keyboard qwerty hidden 0 hardhidden 0", -1));
+	return TCL_OK;
+
+    case BORG_osenvironment: {		/* borg osenvironment op */
+	static const char *const osenvCmds[] = {
+	    "datadir", "downloadcachedir", "externalstoragedir",
+	    "externalstoragepublicdir", "externalstoragestate",
+	    "isexternalstorageemulated", "isexternalstorageremovable",
+	    "rootdir", NULL
+	};
+	enum oe { OE_data, OE_dlcache, OE_ext, OE_extpub, OE_extstate,
+		  OE_emul, OE_remov, OE_root };
+	int sub;
+	const char *home = getenv("HOME");
+	char buf[2048];
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "op ?arg?");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], osenvCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	if (home == NULL) home = "/tmp";
+	switch ((enum oe) sub) {
+	case OE_data:
+	    snprintf(buf, sizeof(buf),
+		"%s/Library/Application Support/undroidwish", home);
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+	    break;
+	case OE_dlcache:
+	    snprintf(buf, sizeof(buf), "%s/Library/Caches", home);
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+	    break;
+	case OE_ext:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj(home, -1));
+	    break;
+	case OE_extpub:
+	    snprintf(buf, sizeof(buf), "%s/Documents", home);
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+	    break;
+	case OE_extstate:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("mounted", -1));
+	    break;
+	case OE_emul: case OE_remov:
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	    break;
+	case OE_root:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("/", -1));
+	    break;
+	}
+	return TCL_OK;
+    }
+
+    case BORG_systemproperties: {		/* borg systemproperties ?name? */
+	if (objc > 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "?name?");
+	    return TCL_ERROR;
+	}
+	if (objc == 3) {
+	    char buf[1024];
+	    if (BorgSysctlStr(Tcl_GetString(objv[2]), buf, sizeof(buf))) {
+		Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+	    }
+	    /* unknown property -> empty (Android behaviour) */
+	} else {
+	    /* No name: a small representative set. */
+	    Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+	    char buf[1024];
+	    const char *names[] = {
+		"kern.ostype", "kern.osrelease", "kern.osproductversion",
+		"hw.model", "hw.machine", "machdep.cpu.brand_string", NULL
+	    };
+	    int i;
+	    for (i = 0; names[i] != NULL; i++) {
+		if (BorgSysctlStr(names[i], buf, sizeof(buf))) {
+		    BorgAddKV(list, names[i], buf);
+		}
+	    }
+	    Tcl_SetObjResult(interp, list);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_locale: {			/* borg locale ?set|lang|tts ?lang?? */
+	if (objc == 2) {
+	    const char *loc = setlocale(LC_ALL, NULL);
+	    if (loc == NULL || loc[0] == '\0' || strcmp(loc, "C") == 0) {
+		loc = getenv("LANG");
+	    }
+	    Tcl_SetObjResult(interp,
+		Tcl_NewStringObj(loc ? loc : "en_US", -1));
+	} else {
+	    const char *op = Tcl_GetString(objv[2]);
+	    if (strcmp(op, "set") == 0 && objc == 4) {
+		setlocale(LC_ALL, Tcl_GetString(objv[3]));
+		Tcl_SetObjResult(interp, objv[3]);
+	    } else if (strcmp(op, "tts") == 0) {
+		Tcl_SetObjResult(interp,
+		    (objc == 4) ? objv[3]
+				: Tcl_NewStringObj("en_US", -1));
+	    } else {
+		/* "lang" or anything else: echo it back */
+		Tcl_SetObjResult(interp, objv[objc - 1]);
+	    }
+	}
+	return TCL_OK;
+    }
+
+    case BORG_notification: {		/* borg notification add|delete|led */
+	static const char *const nCmds[] = {"add", "delete", "led", NULL};
+	enum n { N_add, N_delete, N_led };
+	int sub;
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "add|delete|led ...");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], nCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	switch ((enum n) sub) {
+	case N_add:		/* add id title ?text icon ...? */
+	    if (objc >= 5) {
+		BorgNotify(interp, Tcl_GetString(objv[4]),
+			   (objc > 5) ? Tcl_GetString(objv[5])
+				      : Tcl_GetString(objv[4]));
+	    } else if (objc == 4) {
+		BorgNotify(interp, Tcl_GetString(objv[3]), "");
+	    }
+	    break;
+	case N_delete: case N_led:
+	    /* macOS Notification Center has no per-id removal API here. */
+	    break;
+	}
+	return TCL_OK;
+    }
+
+    case BORG_usbdevices:		/* borg usbdevices ?extended? */
+	return BorgUsbDevices(interp);
+
+    case BORG_usbpermission:		/* borg usbpermission device ?ask? */
+	/* No USB permission gate on macOS. */
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(1));
+	return TCL_OK;
+
+    case BORG_checkpermission: {	/* borg checkpermission ?perms... ask? */
+	if (objc < 3) {
+	    /* query the permission list -> none enumerated */
+	    Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	} else if (objc == 3) {
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(1));	/* granted */
+	} else {
+	    /* last arg is the ask flag; report each requested perm granted */
+	    Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+	    int i;
+	    for (i = 2; i < objc - 1; i++) {
+		Tcl_ListObjAppendElement(NULL, list, Tcl_NewIntObj(1));
+	    }
+	    Tcl_SetObjResult(interp, list);
+	}
+	return TCL_OK;
+    }
+
+    case BORG_bluetooth: {		/* borg bluetooth state|on|off|... */
+	static const char *const btCmds[] = {
+	    "devices", "myaddress", "remoteaddress", "off", "on",
+	    "scanmode", "state", "start_discovery", "cancel_discovery", NULL
+	};
+	enum bt { BT_devices, BT_myaddress, BT_remoteaddress, BT_off, BT_on,
+		  BT_scanmode, BT_state, BT_startdisc, BT_canceldisc };
+	int sub;
+	if ((objc < 3) || (objc > 4)) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "devices|state|... ?arg?");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], btCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	switch ((enum bt) sub) {
+	case BT_state: {
+	    /* Best effort: parse system_profiler for the controller state. */
+	    const char *argv[2] = {"system_profiler", "SPBluetoothDataType"};
+	    Tcl_Obj *out = BorgCapture(interp, 2, argv);
+	    const char *s = "off";
+	    if (out != NULL) {
+		const char *txt = Tcl_GetString(out);
+		if (strstr(txt, "State: On") || strstr(txt, "Powered: On") ||
+		    strstr(txt, "\"on\"")) {
+		    s = "on";
+		}
+		Tcl_DecrRefCount(out);
+	    }
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj(s, -1));
+	    break;
+	}
+	case BT_on: case BT_off: {
+	    /* Try blueutil if installed; otherwise accepted no-op. */
+	    const char *argv[3];
+	    argv[0] = "blueutil";
+	    argv[1] = (sub == BT_on) ? "--power=1" : "--power=0";
+	    argv[2] = NULL;
+	    (void) BorgSpawn(argv);
+	    break;
+	}
+	case BT_scanmode:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("none", -1));
+	    break;
+	case BT_myaddress:
+	case BT_remoteaddress:
+	case BT_devices:
+	    /* Enumeration not implemented here -> empty. */
+	    Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	    break;
+	case BT_startdisc: case BT_canceldisc:
+	    break;
+	}
+	return TCL_OK;
+    }
+
+    case BORG_sharedpreferences:
+	return BorgSharedPrefs(interp, objc, objv);
+
+    case BORG_withdraw:
+	if (objc != 2) {
+	    Tcl_WrongNumArgs(interp, 2, objv, NULL);
+	    return TCL_ERROR;
+	}
+	BorgEvalIgnore(interp, "catch {wm withdraw .}");
+	return TCL_OK;
+
+    case BORG_content: {		/* borg content query|insert|update|delete */
+	static const char *const cCmds[] = {
+	    "delete", "insert", "query", "update", NULL
+	};
+	enum c { C_delete, C_insert, C_query, C_update };
+	int sub;
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "op ...");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], cCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	if ((enum c) sub == C_query) {
+	    return BorgEmptyCursor(interp);
+	}
+	/* insert/update/delete: 0 rows affected. */
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	return TCL_OK;
+    }
+
+    case BORG_onintent: {		/* borg onintent ?command? */
+	if (objc > 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "?command?");
+	    return TCL_ERROR;
+	}
+	if (objc == 3) {
+	    if (borgOnIntent != NULL) Tcl_DecrRefCount(borgOnIntent);
+	    borgOnIntent = objv[2];
+	    Tcl_IncrRefCount(borgOnIntent);
+	} else if (borgOnIntent != NULL) {
+	    Tcl_SetObjResult(interp, borgOnIntent);
+	}
+	return TCL_OK;
+    }
+
+    /* ---- Accepted no-ops / "empty" stubs (no macOS analogue) -------- */
+
+    case BORG_screenorientation:	/* desktop has no rotation */
+	if (objc == 2) {
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("landscape", -1));
+	}
+	return TCL_OK;
+
+    case BORG_systemui:			/* immersive UI flags: report 0 */
+	if (objc == 2) {
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	}
+	return TCL_OK;
+
+    case BORG_tetherinfo:
+	Tcl_SetObjResult(interp,
+	    Tcl_NewStringObj("active {} available {} error {}", -1));
+	return TCL_OK;
+
+    case BORG_phoneinfo:
+    case BORG_providerinfo:
+    case BORG_packageinfo:
+    case BORG_queryconsts:
+    case BORG_queryfields:
+    case BORG_queryfeatures:
+    case BORG_queryactivities:
+    case BORG_queryservices:
+    case BORG_querybroadcastreceivers:
+	/* Nothing to enumerate on the desktop. */
+	Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	return TCL_OK;
+
+    case BORG_sendsms:			/* no telephony */
+    case BORG_cancel:			/* no pending activities */
+    case BORG_ndefread:			/* no NFC */
+    case BORG_ndefwrite:
+    case BORG_ndefformat:
+	return TCL_OK;
+
+    case BORG_shortcut:			/* desktop launcher creation: no-op */
+    case BORG_alarm:			/* per-app alarms: no-op */
+	return TCL_OK;
+
+    case BORG_sensor: {			/* borg sensor list|enable|... */
+	static const char *const sCmds[] = {
+	    "disable", "enable", "get", "list", "state", NULL
+	};
+	enum s { S_disable, S_enable, S_get, S_list, S_state };
+	int sub;
+	if ((objc < 3) || (objc > 4)) {
+	    Tcl_WrongNumArgs(interp, 2, objv,
+			     "list|enable|disable|state|get ?index?");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], sCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	switch ((enum s) sub) {
+	case S_list: case S_get:
+	    Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	    break;
+	case S_state:
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	    break;
+	case S_enable: case S_disable:
+	    break;		/* no Android-style indexed sensors */
+	}
+	return TCL_OK;
+    }
+
+    case BORG_speechrecognition: {	/* borg speechrecognition ... */
+	/* No on-device dictation bridge here; accepted no-op. */
+	return TCL_OK;
+    }
+
+    case BORG_broadcast: {		/* borg broadcast list|register|... */
+	static const char *const bCmds[] = {
+	    "list", "register", "send", "unregister", NULL
+	};
+	int sub;
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "list|register|... ...");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], bCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	if (sub == 0) {			/* list */
+	    Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	}
+	return TCL_OK;
+    }
+
+    case BORG_camera: {			/* borg camera ... */
+	static const char *const camCmds[] = {
+	    "close", "current", "grayimage", "greyimage", "image", "info",
+	    "jpeg", "mirror", "numcameras", "open", "orientation",
+	    "parameters", "start", "state", "stop", "takejpeg", NULL
+	};
+	enum cm { CM_close, CM_current, CM_gray, CM_grey, CM_image, CM_info,
+		  CM_jpeg, CM_mirror, CM_num, CM_open, CM_orient, CM_params,
+		  CM_start, CM_state, CM_stop, CM_takejpeg };
+	int sub;
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "close|open|... ...");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], camCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	/*
+	 * AVFoundation capture is not bridged here yet; report "no cameras"
+	 * so callers degrade gracefully rather than error.
+	 */
+	switch ((enum cm) sub) {
+	case CM_num:
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	    break;
+	case CM_current:
+	    Tcl_SetObjResult(interp, Tcl_NewIntObj(-1));
+	    break;
+	case CM_state:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("closed", -1));
+	    break;
+	case CM_mirror:
+	    Tcl_SetObjResult(interp, Tcl_NewStringObj("0 0", -1));
+	    break;
+	default:
+	    break;
+	}
+	return TCL_OK;
+    }
+
+    case BORG_location: {		/* borg location get|start|stop|... */
+	static const char *const lCmds[] = {
+	    "get", "gps", "nmea", "satellites", "start", "stop", NULL
+	};
+	int sub;
+	if (objc < 3) {
+	    Tcl_WrongNumArgs(interp, 2, objv, "get|start|stop|... ...");
+	    return TCL_ERROR;
+	}
+	if (Tcl_GetIndexFromObj(interp, objv[2], lCmds, "option", 0,
+				&sub) != TCL_OK) {
+	    return TCL_ERROR;
+	}
+	/*
+	 * CoreLocation needs a bundled app with usage description and user
+	 * consent; not bridged here.  get/gps/satellites/nmea -> empty,
+	 * start/stop -> accepted no-op.
+	 */
+	return TCL_OK;
+    }
+
+    }	/* switch */
+
+    /* Unreachable: every enum value handled above. */
+    return TCL_OK;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * Borg_Init --
+ *
+ *	Register the "borg" command.  Compatible with the Android Borg_Init
+ *	prototype (tkBorg.h) so tkAppInit.c can call it unchanged.
+ *----------------------------------------------------------------------
+ */
+
+int
+Borg_Init(Tcl_Interp *interp)
+{
+    if (Tcl_InitStubs(interp, "8.5", 0) == NULL) {
+	return TCL_ERROR;
+    }
+    Tcl_CreateObjCommand(interp, "borg", BorgObjCmd, (ClientData) interp, NULL);
+    Tcl_PkgProvide(interp, "Borg", "1.0");
+    return TCL_OK;
+}
+
+#else /* !__APPLE__ */
+
+/*
+ * On non-Apple desktops this translation unit is empty; the platform's own
+ * borg (if any) is provided elsewhere.
+ */
+int
+Borg_Init(Tcl_Interp *interp)
+{
+    return TCL_OK;
+}
+
+#endif /* __APPLE__ */
