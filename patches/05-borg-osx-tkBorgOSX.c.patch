+/*
+ *----------------------------------------------------------------------
+ * Screen brightness via the private DisplayServices framework (dlopen'd),
+ * which is the only reliable absolute brightness API on Apple Silicon.
+ *----------------------------------------------------------------------
+ */
+
+typedef int (*DSGetBrightnessFn)(CGDirectDisplayID, float *);
+typedef int (*DSSetBrightnessFn)(CGDirectDisplayID, float);
+
+static int
+BorgBrightnessFns(DSGetBrightnessFn *getp, DSSetBrightnessFn *setp)
+{
+    static int tried = 0;
+    static DSGetBrightnessFn getfn = NULL;
+    static DSSetBrightnessFn setfn = NULL;
+
+    if (!tried) {
+	void *h = dlopen("/System/Library/PrivateFrameworks/"
+			 "DisplayServices.framework/DisplayServices", RTLD_LAZY);
+	if (h != NULL) {
+	    getfn = (DSGetBrightnessFn) dlsym(h, "DisplayServicesGetBrightness");
+	    setfn = (DSSetBrightnessFn) dlsym(h, "DisplayServicesSetBrightness");
+	}
+	tried = 1;
+    }
+    if (getp) *getp = getfn;
+    if (setp) *setp = setfn;
+    return (getfn != NULL && setfn != NULL);
+}
+
+/*
+ *----------------------------------------------------------------------
+ * sysctl string helper.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgSysctlStr(const char *name, char *buf, size_t buflen)
+{
+    size_t len = buflen;
+
+    buf[0] = '\0';
+    if (sysctlbyname(name, buf, &len, NULL, 0) == 0) {
+	if (len < buflen) {
+	    buf[len] = '\0';
+	}
+	return 1;
+    }
+    return 0;
+}
