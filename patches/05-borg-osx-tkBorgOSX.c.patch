+/*
+ *----------------------------------------------------------------------
+ * Embedded Tk helpers for toast / spinner.  Sourced lazily on first use;
+ * become no-ops if Tk is not present.
+ *----------------------------------------------------------------------
+ */
+
+static const char borgTkHelpers[] =
+"namespace eval ::borg::ui {}\n"
+/* Find a Canvas widget to draw the toast onto (true anti-aliased rounded
+ * corners, since sdl2tk has no per-pixel window transparency). */
+"proc ::borg::ui::_findcanvas {} {\n"
+"  set q [list .]\n"
+"  while {[llength $q]} {\n"
+"    set w [lindex $q 0]; set q [lrange $q 1 end]\n"
+"    if {[winfo exists $w] && [winfo class $w] eq {Canvas}} { return $w }\n"
+"    catch { foreach c [winfo children $w] { lappend q $c } }\n"
+"  }\n"
+"  return {}\n"
+"}\n"
+/* Rounded-rectangle as a smooth (AGG anti-aliased) polygon. */
+"proc ::borg::ui::_roundrect {c x1 y1 x2 y2 r args} {\n"
+"  set p [list $x1 [expr {$y1+$r}] $x1 $y1 [expr {$x1+$r}] $y1 [expr {$x2-$r}] $y1 $x2 $y1 $x2 [expr {$y1+$r}] $x2 [expr {$y2-$r}] $x2 $y2 [expr {$x2-$r}] $y2 [expr {$x1+$r}] $y2 $x1 $y2 $x1 [expr {$y2-$r}]]\n"
+"  return [$c create polygon $p -smooth true {*}$args]\n"
+"}\n"
+/* SDL-layer toast: render the rounded toast onto an offscreen canvas with a
+ * magenta (chroma-key) background, then hand the pixels to the SDL present
+ * layer (sdltk borgtoast) so it is always foreground -- never hidden behind a
+ * blt::graph or other non-canvas widget.  Errors out if sdltk borgtoast is
+ * not available so the caller can fall back to the in-canvas overlay. */
+"proc ::borg::ui::_toast_sdl {text ms} {\n"
+"  set key #ff00ff\n"
+"  set sw [winfo screenwidth .]\n"
+"  set sh [winfo screenheight .]\n"
+"  set fs [expr {int($sh/30.0*0.7)}]; if {$fs < 10} { set fs 10 }\n"
+"  catch {destroy ._borgtoast}\n"
+"  set rc [catch {\n"
+"    set t [toplevel ._borgtoast -bg $key -bd 0 -highlightthickness 0]\n"
+"    wm overrideredirect $t 1\n"
+"    catch {wm attributes $t -topmost 1}\n"
+"    set c [canvas $t.c -bg $key -highlightthickness 0 -bd 0]\n"
+"    pack $c\n"
+"    set padx $fs; set pady [expr {int($fs*0.7)}]; set r [expr {int($fs*1.4)}]\n"
+"    set maxw [expr {int($sw*0.8)}]\n"
+"    set tid [$c create text $padx $pady -text $text -fill white -anchor nw -justify center -font [list Helvetica $fs] -width $maxw -tags t]\n"
+"    lassign [$c bbox $tid] bx1 by1 bx2 by2\n"
+"    set tw [expr {$bx2-$bx1}]; set th [expr {$by2-$by1}]\n"
+"    set W [expr {$tw+2*$padx}]; set H [expr {$th+2*$pady}]\n"
+"    set rid [::borg::ui::_roundrect $c 0 0 $W $H $r -fill #444444 -outline {} -tags bg]\n"
+"    $c lower $rid $tid\n"
+"    $c configure -width $W -height $H\n"
+"    wm geometry $t ${W}x${H}+[expr {($sw-$W)/2}]+[expr {$sh-$H-int($sh*0.02)}]\n"
+"    update idletasks\n"
+"    sdltk borgtoast $c $ms\n"
+"  } emsg]\n"
+"  catch {destroy ._borgtoast}\n"
+"  if {$rc} { return -code error $emsg }\n"
+"}\n"
+"proc ::borg::ui::toast {text {long 0}} {\n"
+"  if {[catch {package present Tk}]} { return }\n"
+"  set ms [expr {$long ? 3500 : 2000}]\n"
+"  if {([info commands sdltk] ne {}) && ![catch {::borg::ui::_toast_sdl $text $ms}]} { return }\n"
+"  set c [::borg::ui::_findcanvas]\n"
+"  if {$c ne {}} {\n"
+"    catch {$c delete _borgtoast}\n"
+"    set cw [winfo width $c]; set ch [winfo height $c]\n"
+"    if {$cw < 50} { set cw [winfo screenwidth $c] }\n"
+"    if {$ch < 50} { set ch [winfo screenheight $c] }\n"
+"    set fs [expr {int($ch/30.0*0.7)}]; if {$fs < 10} { set fs 10 }\n"
+"    set tx [expr {$cw/2}]; set ty [expr {int($ch*0.964)}]\n"
+"    set tid [$c create text $tx $ty -text $text -fill white -anchor center -justify center -font [list Helvetica $fs] -width [expr {int($cw*0.8)}] -tags _borgtoast]\n"
+"    lassign [$c bbox $tid] bx1 by1 bx2 by2\n"
+"    set padx $fs; set pady [expr {int($fs*0.7)}]; set r [expr {int($fs*1.4)}]\n"
+"    set rid [::borg::ui::_roundrect $c [expr {$bx1-$padx}] [expr {$by1-$pady}] [expr {$bx2+$padx}] [expr {$by2+$pady}] $r -fill #444444 -outline {} -tags _borgtoast]\n"
+"    $c lower $rid $tid\n"
+"    after $ms [list catch [list $c delete _borgtoast]]\n"
+"    return\n"
+"  }\n"
+/* Fallback (no canvas): borderless toplevel, white-on-black (rectangular --
+ * sdl2tk can't shape a window). */
+"  catch {destroy ._borgtoast}\n"
+"  set t [toplevel ._borgtoast -bg #444444 -bd 0 -highlightthickness 0]\n"
+"  catch {wm overrideredirect $t 1}\n"
+"  catch {wm attributes $t -topmost 1}\n"
+"  catch {wm attributes $t -alpha 0.9}\n"
+"  label $t.l -text $text -fg white -bg #444444 -padx 17 -pady 10\n"
+"  pack $t.l\n"
+"  update idletasks\n"
+"  set sw [winfo screenwidth $t]; set sh [winfo screenheight $t]\n"
+"  set w [winfo reqwidth $t.l]; set h [winfo reqheight $t.l]\n"
+"  catch {wm geometry $t +[expr {($sw-$w)/2}]+[expr {$sh-$h-int(($sh-int($sh*0.8)-$h)*0.2)}]}\n"
+"  after $ms [list destroy $t]\n"
+"}\n"
+"proc ::borg::ui::spinner {on} {\n"
+"  if {[catch {package present Tk}]} { return }\n"
+"  if {$on} { catch {. configure -cursor watch} } else { catch {. configure -cursor {}} }\n"
+"  catch {update idletasks}\n"
+"}\n";
