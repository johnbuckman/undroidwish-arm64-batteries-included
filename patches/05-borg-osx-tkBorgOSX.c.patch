+/*
+ *----------------------------------------------------------------------
+ * displaymetrics via CoreGraphics.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgDisplayMetrics(Tcl_Interp *interp)
+{
+    CGDirectDisplayID d = CGMainDisplayID();
+    size_t wpx = CGDisplayPixelsWide(d);
+    size_t hpx = CGDisplayPixelsHigh(d);
+    CGSize mm = CGDisplayScreenSize(d);	/* millimetres */
+    double xdpi = 96.0, ydpi = 96.0, density, sdensity;
+    int ddpi;
+    char buf[256];
+
+    if (mm.width > 0.0) {
+	xdpi = (double) wpx / (mm.width / 25.4);
+    }
+    if (mm.height > 0.0) {
+	ydpi = (double) hpx / (mm.height / 25.4);
+    }
+    /* Android density baseline is 160dpi. */
+    density = ((xdpi + ydpi) / 2.0) / 160.0;
+    ddpi = (int)(density * 160.0 + 0.5);
+    sdensity = density;
+    snprintf(buf, sizeof(buf),
+	     "density %.3g densitydpi %d width %lu height %lu "
+	     "xdpi %.4g ydpi %.4g scaleddensity %.3g rotation 0",
+	     density, ddpi, (unsigned long) wpx, (unsigned long) hpx,
+	     xdpi, ydpi, sdensity);
+    Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+    return TCL_OK;
+}
