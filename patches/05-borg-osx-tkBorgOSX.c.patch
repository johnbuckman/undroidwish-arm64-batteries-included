+/*
+ * Friendly Apple product name (e.g. "MacBook Air"), cached.  macOS no longer
+ * encodes the product line in hw.model ("Mac16,12"), so we read the marketing
+ * name from system_profiler once.  Falls back to "Mac".
+ */
+static const char *
+BorgMacProduct(void)
+{
+    static char prod[128] = "";
+    static int done = 0;
+
+    if (!done) {
+	FILE *fp;
+
+	done = 1;
+	fp = popen("/usr/sbin/system_profiler SPHardwareDataType 2>/dev/null"
+		   " | /usr/bin/awk -F': ' '/Model Name/{print $2; exit}'", "r");
+	if (fp != NULL) {
+	    if (fgets(prod, sizeof(prod), fp) != NULL) {
+		size_t n = strlen(prod);
+		while (n > 0 && (prod[n-1] == '\n' || prod[n-1] == '\r' ||
+				 prod[n-1] == ' ')) {
+		    prod[--n] = '\0';
+		}
+	    }
+	    pclose(fp);
+	}
+	if (prod[0] == '\0') {
+	    strlcpy(prod, "Mac", sizeof(prod));
+	}
+    }
+    return prod;
+}
+
+static int
+BorgOSBuildInfo(Tcl_Interp *interp)
+{
+    Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+    char osver[128], darwin[128], model[128], machine[64], cpu[256], host[256];
+    char target[128], fp[1024];
+
+    BorgSysctlStr("kern.osproductversion", osver, sizeof(osver));
+    BorgSysctlStr("kern.osversion", darwin, sizeof(darwin));
+    BorgSysctlStr("hw.model", model, sizeof(model));
+    BorgSysctlStr("hw.machine", machine, sizeof(machine));
+    BorgSysctlStr("machdep.cpu.brand_string", cpu, sizeof(cpu));
+    if (!BorgSysctlStr("hw.target", target, sizeof(target))) {
+	target[0] = '\0';
+    }
+    if (gethostname(host, sizeof(host)) != 0) host[0] = '\0';
+
+    /*
+     * Fill the standard (Android-shaped) osbuildinfo keys with real Apple
+     * values so callers identify the platform from the EXISTING keys -- no
+     * non-standard "borg platform"/"os" key needed:
+     *   manufacturer "Apple"  -> Apple (vs the device maker on Android)
+     *   model        hw.model -> "Mac..."  (iWish reports "iPad.."/"iPhone.." on iOS)
+     *   product      "undroidwish"          (the iWish build reports "iWish")
+     * Android-style fingerprint: brand/product/device:release/id/incr:type/tags
+     */
+    snprintf(fp, sizeof(fp), "Apple/Mac/%s:%s/%s/0:user/release-keys",
+	     model, osver, darwin);
+
+    BorgAddKV(list, "version.codename", "REL");
+    BorgAddKV(list, "version.incremental", darwin);
+    BorgAddKV(list, "version.release", osver);
+    BorgAddKV(list, "version.sdk", "0");	/* Android API level; no Apple equiv */
+    BorgAddKV(list, "board", target[0] ? target : model);
+    BorgAddKV(list, "bootloader", "");
+    BorgAddKV(list, "brand", "Apple");
+    BorgAddKV(list, "cpu_abi", machine);
+    BorgAddKV(list, "cpu_abi2", "");
+    BorgAddKV(list, "device", model);
+    BorgAddKV(list, "display", darwin);
+    BorgAddKV(list, "fingerprint", fp);
+    BorgAddKV(list, "hardware", cpu);
+    BorgAddKV(list, "host", host);
+    BorgAddKV(list, "id", darwin);
+    BorgAddKV(list, "manufacturer", "Apple");
+    BorgAddKV(list, "model", model);
+    BorgAddKV(list, "product", BorgMacProduct());
+    BorgAddKV(list, "serial", "unknown");
+    BorgAddKV(list, "tags", "release-keys");
+    BorgAddKV(list, "time", "0");
+    BorgAddKV(list, "type", "user");
+    BorgAddKV(list, "user", getenv("USER") ? getenv("USER") : "");
+    BorgAddKV(list, "radio", "");
+    Tcl_SetObjResult(interp, list);
+    return TCL_OK;
+}
