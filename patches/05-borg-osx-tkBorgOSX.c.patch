+/*
+ *----------------------------------------------------------------------
+ * An empty cursor object, so "borg content query" can return a usable
+ * (zero-row) cursor and callers never error on the cursor protocol.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgCursorObjCmd(ClientData cd, Tcl_Interp *interp, int objc,
+		 Tcl_Obj *const objv[])
+{
+    static const char *const cursorCmds[] = {
+	"close", "columnnames", "count", "getblob", "getdouble",
+	"getint", "getpos", "getrow", "getstring", "gettype", "isnull",
+	"move", "moveto", NULL
+    };
+    enum cur {
+	CUR_close, CUR_columnnames, CUR_count, CUR_getblob, CUR_getdouble,
+	CUR_getint, CUR_getpos, CUR_getrow, CUR_getstring, CUR_gettype,
+	CUR_isnull, CUR_move, CUR_moveto
+    };
+    int cmd;
+
+    if (objc < 2) {
+	Tcl_WrongNumArgs(interp, 1, objv, "option ?arg ...?");
+	return TCL_ERROR;
+    }
+    if (Tcl_GetIndexFromObj(interp, objv[1], cursorCmds, "option", 0,
+			    &cmd) != TCL_OK) {
+	return TCL_ERROR;
+    }
+    switch ((enum cur) cmd) {
+    case CUR_close:
+	Tcl_DeleteCommand(interp, Tcl_GetString(objv[0]));
+	break;
+    case CUR_columnnames: case CUR_getrow:
+	Tcl_SetObjResult(interp, Tcl_NewListObj(0, NULL));
+	break;
+    case CUR_count: case CUR_getint: case CUR_getpos:
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(0));
+	break;
+    case CUR_getdouble:
+	Tcl_SetObjResult(interp, Tcl_NewDoubleObj(0.0));
+	break;
+    case CUR_isnull:
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(1));
+	break;
+    case CUR_move: case CUR_moveto:
+	Tcl_SetObjResult(interp, Tcl_NewIntObj(0));	/* no movement */
+	break;
+    case CUR_getblob: case CUR_getstring: case CUR_gettype:
+	Tcl_SetObjResult(interp, Tcl_NewStringObj("", -1));
+	break;
+    }
+    return TCL_OK;
+}
