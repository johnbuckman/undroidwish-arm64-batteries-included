+/*
+ *----------------------------------------------------------------------
+ * networkinfo: "none" / "wifi" / "ethernet" from getifaddrs.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgNetworkInfo(Tcl_Interp *interp)
+{
+    struct ifaddrs *ifap = NULL, *ifa;
+    const char *result = "none";
+
+    if (getifaddrs(&ifap) == 0) {
+	for (ifa = ifap; ifa != NULL; ifa = ifa->ifa_next) {
+	    if (ifa->ifa_addr == NULL) continue;
+	    if (ifa->ifa_addr->sa_family != AF_INET) continue;
+	    if (!(ifa->ifa_flags & IFF_UP)) continue;
+	    if (!(ifa->ifa_flags & IFF_RUNNING)) continue;
+	    if (ifa->ifa_flags & IFF_LOOPBACK) continue;
+	    /*
+	     * Heuristic: en* interfaces are Wi-Fi or wired Ethernet; we can't
+	     * distinguish without SystemConfiguration, so report the common
+	     * "wifi" for en* and "ethernet" for anything else with a route.
+	     */
+	    if (strncmp(ifa->ifa_name, "en", 2) == 0) {
+		result = "wifi";
+		break;
+	    }
+	    result = "ethernet";
+	}
+	freeifaddrs(ifap);
+    }
+    Tcl_SetObjResult(interp, Tcl_NewStringObj(result, -1));
+    return TCL_OK;
+}
