+static int borgTkHelpersLoaded = 0;
+
+static void
+BorgEnsureTkHelpers(Tcl_Interp *interp)
+{
+    if (!borgTkHelpersLoaded) {
+	BorgEvalIgnore(interp, borgTkHelpers);
+	borgTkHelpersLoaded = 1;
+    }
+}
